# --- DATABASE ---
# cPanel-provisioned PostgreSQL (production/staging run on cPanel Node hosting, per the SRS).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AUTH & JWT ---
JWT_SECRET="generate-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"
EMAIL_TOKEN_EXPIRES_IN="24h"

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- GOOGLE GEMINI AI ---
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# --- EMAIL (SMTP) --- Zoho Mail (Pro/organization plan)
# Host is smtppro.zoho.com for a Zoho Mail Pro/organization account (not
# the smtp.zoho.com used by free/individual Zoho Mail) — confirm which
# your org is on. Use an Account Security -> App Password, not the real
# login password (Zoho requires this for third-party SMTP clients).
SMTP_HOST="smtppro.zoho.com"
SMTP_PORT="465"
SMTP_SECURE="true" # set to "false" for port 587 (STARTTLS)
SMTP_USER="your-email@yourdomain.com"
SMTP_PASS="your-zoho-app-password"
EMAIL_FROM="Vertex International <noreply@vertexinternational.com>"
# Staff inbox notified when a partner submits a candidate (SRS FR-5.1) —
# address not yet provided by the business; leave unset until it is.
PARTNER_SUBMISSION_NOTIFY_EMAIL=""
# Staff inbox for the public-forms email bridge (Candidate Information
# Form while Admin Settings → Public Form Intake Mode = Email, and the
# Contact form, always). See src/app/api/public-intake/application/route.ts
# and src/app/api/contact/route.ts.
PUBLIC_FORMS_NOTIFY_EMAIL=""

# --- PAYMENTS (STRIPE) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- PAYMENTS (PAYPAL) ---
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_API_BASE="https://api-m.sandbox.paypal.com" # or https://api-m.paypal.com for live

# --- FILE UPLOADS ---
# Must stay OUTSIDE the /public directory — anything under /public is served
# statically with no access control. Documents are served only through the
# signed-URL API route (SRS FR-1.6).
UPLOAD_DIR="./storage/documents"
MAX_FILE_SIZE_MB="5"

# --- VERCEL BLOB (demo deployments only) ---
# Local disk (above) doesn't persist on Vercel's serverless functions, so a
# demo deployment hosted there needs a different store. Only takes effect
# when BOTH this is set AND the runtime is actually on Vercel
# (process.env.VERCEL, set automatically by Vercel itself) — the real
# cPanel production/staging target always uses local disk + R2 regardless
# of whether this happens to be present in its env. Get this from the
# Vercel project's Storage tab → the Blob store → the token shown there
# (NOT the store's BLOB_STORE_ID or BLOB_WEBHOOK_PUBLIC_KEY, which are for
# different purposes).
BLOB_READ_WRITE_TOKEN=""

# --- DOCUMENT BACKUP (CLOUDFLARE R2, S3-COMPATIBLE) ---
# Optional but strongly recommended (SRS NFR-7 backup/recovery). Local disk
# is the primary store; if these are unset, backup/self-heal is skipped and
# local disk becomes the only copy of candidate documents.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="vertex-documents-backup"

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="10"
