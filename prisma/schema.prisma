// Vertex International Recruitment — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  candidate
  regional_recruiter
  country_supervisor
  inhouse_supervisor
  director
  admin
  // Solely responsible for posting/editing/closing job listings — not part
  // of the three-tier operational hierarchy (Regional Supervisory
  // Operational Workflow) and deliberately kept out of STAFF_ROLES so it
  // doesn't incidentally inherit broader candidate/application access.
  marketing
  // An external agency/partner's own login (SRS FR-5.1), admin-provisioned
  // — not internal staff, so deliberately kept out of STAFF_ROLES same as
  // marketing. Submits candidates through its own portal; never enters the
  // internal recruiter/screening/verification funnel.
  partner
}

enum ApplicationStatus {
  submitted
  under_review
  interview
  approved
  rejected
}

enum JobStatus {
  active
  closed
  draft
}

model User {
  id             String   @id @default(cuid())
  full_name      String
  email          String   @unique
  password_hash  String?
  google_id      String?  @unique
  phone          String?
  country        String?
  role           Role     @default(candidate)
  email_verified Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Agent-network structure (SRS FR-1.1, FR-1.3, FR-1.4)
  supervisor_id       String?
  supervisor          User?    @relation("Supervision", fields: [supervisor_id], references: [id], onDelete: SetNull)
  reports             User[]   @relation("Supervision")
  assigned_country_id String?
  assigned_country    Country? @relation(fields: [assigned_country_id], references: [id], onDelete: SetNull)

  candidate          Candidate?
  partner            Partner?
  payments           Payment[]
  sourced_candidates Candidate[] @relation("RecruiterCandidates")
  submitted_reports  Report[]    @relation("SubmittedReports")
  campaigns_created  Campaign[]  @relation("CampaignCreator")

  case_stage_events_owned     CaseStageEvent[]   @relation("CaseStageOwner")
  case_payments_recorded      CasePayment[]      @relation("CasePaymentRecorder")
  fee_policies_updated        FeePolicy[]        @relation("FeePolicyUpdater")
  contracts_created           Contract[]         @relation("ContractCreator")
  partner_candidates_reviewed PartnerCandidate[] @relation("PartnerCandidateReviewer")
  recruiter_targets_received  RecruiterTarget[]  @relation("RecruiterTargetRecruiter")
  recruiter_targets_set       RecruiterTarget[]  @relation("RecruiterTargetSetter")

  @@index([email])
  @@index([supervisor_id])
  @@index([assigned_country_id])
}

model Region {
  id        String    @id @default(cuid())
  name      String    @unique
  countries Country[]

  campaign_targets CampaignTarget[]
}

// The Country reference-data model doubles as the "preferred programme
// destination" a candidate selects on the Candidate Information Form —
// admin populates this with the European programme countries Vertex
// actually places into (Poland, Belarus, Italy, etc.), not a general
// world-country list.
model Country {
  id        String @id @default(cuid())
  name      String @unique
  region_id String
  region    Region @relation(fields: [region_id], references: [id], onDelete: Restrict)

  users                      User[]
  candidates                 Candidate[]
  reports                    Report[]
  campaign_targets           CampaignTarget[]
  fee_policies               FeePolicy[]
  document_requirements      CountryDocumentRequirement[]
  preferred_by_1             Application[]                @relation("PreferredCountry1")
  preferred_by_2             Application[]                @relation("PreferredCountry2")
  preferred_by_3             Application[]                @relation("PreferredCountry3")
  current_located_by         Application[]                @relation("CurrentLocationCountry")
  partner_preferred_by_1     PartnerCandidate[]           @relation("PartnerPreferredCountry1")
  partner_preferred_by_2     PartnerCandidate[]           @relation("PartnerPreferredCountry2")
  partner_preferred_by_3     PartnerCandidate[]           @relation("PartnerPreferredCountry3")
  partner_current_located_by PartnerCandidate[]           @relation("PartnerCurrentLocation")

  @@index([region_id])
}

// Admin-managed "type of work" taxonomy (Candidate Information Form §1,
// "Preferred Type of Work") — e.g. Warehouse, Agriculture, Hotel, Driving.
model Sector {
  id                 String             @id @default(cuid())
  name               String             @unique
  created_at         DateTime           @default(now())
  applications       Application[]
  partner_candidates PartnerCandidate[]
}

// Which documents a given destination country actually requires (form §3:
// "Required for: Poland" etc.) — admin-configurable rather than a
// hardcoded per-country list, so a new programme country's requirements
// don't need a code change.
model CountryDocumentRequirement {
  id               String                  @id @default(cuid())
  country_id       String
  country          Country                 @relation(fields: [country_id], references: [id], onDelete: Cascade)
  document_type    String
  requirement_type DocumentRequirementType @relation(fields: [document_type], references: [key], onDelete: Cascade)
  created_at       DateTime                @default(now())

  @@unique([country_id, document_type])
  @@index([country_id])
}

// Admin-managed document requirement taxonomy (replaces the old fixed
// DocumentType enum) — lets admin add a brand-new requirement type from
// the UI and have it immediately usable across the Candidate Information
// Form / Agency form checklist, per-country requirements, and uploads,
// with no code change or deploy. `key` is the stable identifier stored on
// Document.type/CountryDocumentRequirement.document_type/documents_available
// arrays; `is_universal` marks the fixed cv/passport/passport_photo set
// required for every programme regardless of destination.
model DocumentRequirementType {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  is_universal Boolean  @default(false)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())

  documents            Document[]
  country_requirements CountryDocumentRequirement[]

  @@index([is_universal])
}

enum CandidateSource {
  self_registered
  recruiter_sourced
  partner_sourced
}

enum CandidateLifecycleStatus {
  identified
  screened
  guided_to_apply
  submitted
  reported
  verified
  approved
}

model Candidate {
  id                 String    @id @default(cuid())
  user_id            String?   @unique // nullable: a recruiter-sourced lead may not have an account yet (SRS FR-2.1)
  passport_number    String?
  passport_expiry    DateTime? // every programme requires >= 6 months validity (Candidate Information Form §2)
  date_of_birth      DateTime?
  nationality        String?
  second_nationality String?
  current_occupation String?
  highest_education  String?
  home_address       String?   @db.Text
  whatsapp_number    String?
  marital_status     String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  // Pre-registration identity (SRS FR-2.1, FR-2.8) — only meaningful when
  // user_id is null. Once a User is linked, that record's full_name/
  // phone/email become authoritative instead.
  full_name String?
  phone     String?
  email     String?

  // Target role/position (SRS FR-2.8 candidate-list data point). Free text
  // for now — no formal job/case-matching model exists yet (Phase 4).
  desired_role String?

  // Agent-network attribution (SRS FR-1.4, FR-2.3)
  source           CandidateSource          @default(self_registered)
  recruiter_id     String?
  recruiter        User?                    @relation("RecruiterCandidates", fields: [recruiter_id], references: [id], onDelete: SetNull)
  country_id       String?
  country          Country?                 @relation(fields: [country_id], references: [id], onDelete: SetNull)
  lifecycle_status CandidateLifecycleStatus @default(identified)

  // Partner CRM attribution (SRS FR-5.1) — set only when this Candidate is
  // bridged from a partner's own PartnerCandidate submission (job-
  // assignment step, not built yet — see PartnerCandidate below), never
  // editable afterward via a general edit form.
  partner_id String?
  partner    Partner? @relation(fields: [partner_id], references: [id], onDelete: SetNull)

  // Screening gate (SRS FR-2.5) + verification-return workflow (FR-2.7)
  consent_given Boolean   @default(false)
  consent_at    DateTime?
  return_reason String?   @db.Text

  // The screening gate's pass/fail outcome, persisted — "screening result"
  // is its own standard report-content field, distinct from status
  // (Regional Supervisory Operational Workflow p.7), not just a live gate
  // check that vanishes the moment the request completes. Null until the
  // gate has actually been evaluated once.
  screening_result       Boolean?
  screening_evaluated_at DateTime?

  user                     User?             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  applications             Application[]
  documents                Document[]
  // Set once this Candidate was bridged from a partner's own submission
  // (future job-assignment step, not exercised yet) rather than created
  // directly.
  partner_candidate_origin PartnerCandidate?

  @@index([user_id])
  @@index([recruiter_id])
  @@index([country_id])
  @@index([partner_id])
}

// police_clearance already covers the Candidate Information Form's
// "Criminal Record Certificate" — no separate type needed for it.
enum VerificationStatus {
  pending
  verified
  rejected
}

model Document {
  id                  String                  @id @default(cuid())
  candidate_id        String
  type                String
  requirement_type    DocumentRequirementType @relation(fields: [type], references: [key], onDelete: Restrict)
  storage_path        String // private-bucket path; never a public URL (SRS FR-1.6)
  verification_status VerificationStatus      @default(pending)
  verified_by         String?
  verified_at         DateTime?
  uploaded_at         DateTime                @default(now())

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)

  @@index([candidate_id])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  entity_type String
  entity_id   String
  action      String // create | update | delete | verify | approve
  actor_id    String?
  before      Json?
  after       Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([actor_id])
}

// ── Phase 3: Control, Reporting & Governance ────────────────────────────

enum ReportCycle {
  daily
  weekly
  monthly
}

enum ScopeLevel {
  recruiter
  country
}

enum ReportStatus {
  draft
  submitted
  verified
  consolidated
  returned
}

// A recruiter's daily/weekly submission (scope_level: recruiter) rolls up
// via parent_report_id into their supervisor's country-level report
// (scope_level: country) — the escalation path (SRS FR-3.7) made concrete
// as data, not just a permission chain. `content` snapshots the candidate
// list / KPI summary at submission time (SRS FR-3.4) — a deliberate,
// disclosed duplication of data computable from Candidate/Application,
// since a report is a point-in-time record, not a live view: it must not
// silently change after submission just because the underlying candidates
// move on to new statuses.
model Report {
  id               String       @id @default(cuid())
  type             ReportCycle
  scope_level      ScopeLevel
  country_id       String?
  country          Country?     @relation(fields: [country_id], references: [id], onDelete: SetNull)
  submitted_by     String
  submitter        User         @relation("SubmittedReports", fields: [submitted_by], references: [id], onDelete: Cascade)
  period_start     DateTime
  period_end       DateTime
  status           ReportStatus @default(draft)
  content          Json
  return_reason    String?      @db.Text
  parent_report_id String?
  parent_report    Report?      @relation("ReportRollup", fields: [parent_report_id], references: [id], onDelete: SetNull)
  child_reports    Report[]     @relation("ReportRollup")
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@index([submitted_by])
  @@index([country_id])
  @@index([status])
  @@index([type, period_start])
}

enum CampaignStatus {
  draft
  active
  closed
}

// Criteria/requirements are free-form per campaign (roles, quotas,
// eligibility rules) — modeled as Json rather than a rigid schema since
// the SRS doesn't specify a fixed shape and campaigns vary widely by
// destination market (SRS FR-3.3).
model Campaign {
  id         String         @id @default(cuid())
  name       String
  criteria   Json
  status     CampaignStatus @default(draft)
  created_by String
  creator    User           @relation("CampaignCreator", fields: [created_by], references: [id], onDelete: Cascade)
  start_date DateTime
  end_date   DateTime // a campaign has a bounded timeline (SRS FR-3.3), not an open-ended one
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  targets CampaignTarget[]

  @@index([status])
  @@index([created_by])
}

enum CampaignMetric {
  agent_signups
  applicant_flow
  conversion_rate
}

// A target cascades to exactly one country, one region, or neither
// (campaign-wide) — never more than one scope per row, so "actuals"
// aggregation always has an unambiguous target to compare against.
model CampaignTarget {
  id           String         @id @default(cuid())
  campaign_id  String
  campaign     Campaign       @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  metric       CampaignMetric
  country_id   String?
  country      Country?       @relation(fields: [country_id], references: [id], onDelete: SetNull)
  region_id    String?
  region       Region?        @relation(fields: [region_id], references: [id], onDelete: SetNull)
  target_value Float
  created_at   DateTime       @default(now())

  recruiter_targets RecruiterTarget[]

  @@index([campaign_id])
  @@index([country_id])
  @@index([region_id])
}

// A Country Supervisor's personal allocation of a country-scoped
// CampaignTarget across their own recruiters — the campaign target is
// the team-wide number In-House set; this is how much of it a specific
// recruiter is on the hook for. Deliberately tied to one CampaignTarget
// row (not a freestanding number) so a recruiter's target always traces
// back to a real, currently-active campaign goal, not an orphaned figure.
model RecruiterTarget {
  id                 String         @id @default(cuid())
  campaign_target_id String
  campaign_target    CampaignTarget @relation(fields: [campaign_target_id], references: [id], onDelete: Cascade)
  recruiter_id       String
  recruiter          User           @relation("RecruiterTargetRecruiter", fields: [recruiter_id], references: [id], onDelete: Cascade)
  target_value       Float
  set_by             String
  setter             User           @relation("RecruiterTargetSetter", fields: [set_by], references: [id], onDelete: SetNull)
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  @@unique([campaign_target_id, recruiter_id])
  @@index([recruiter_id])
}

model Job {
  id              String    @id @default(cuid())
  title           String
  country         String
  city            String
  category        String?
  salary_range    String?
  job_description String    @db.Text
  requirements    String    @db.Text
  status          JobStatus @default(active)
  application_fee Float?    @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Vertex's own work-permit programme pricing (Service & Pricing List),
  // one row per opportunity — deliberately NOT keyed by country, since a
  // single country (e.g. Czech Republic) can have several programmes at
  // different price points. Every programme follows the same fixed 20% /
  // 40% / 40% (documentation / permit / visa) split of service_fee_gbp, so
  // only the total is stored; the stage amounts are derived on render.
  visa_type          String?
  duration_permit    String?
  processing_time    String?
  service_fee_gbp    Float?
  visa_success_rates String? @db.Text

  // Which employer/client this vacancy is actually for (SRS FR-5.2) —
  // optional since not every posting is linked to an on-file client yet.
  employer_client_id String?
  employer_client    EmployerClient? @relation(fields: [employer_client_id], references: [id], onDelete: SetNull)

  applications Application[]
  payments     Payment[]

  @@index([status])
  @@index([country])
  @@index([employer_client_id])
}

enum ContactChannel {
  email
  whatsapp
  phone
}

// A candidate's submission of the Candidate Information Form — currently a
// general programme-interest application, not an application to a specific
// job listing, since jobs aren't listed on the platform yet (job_id is
// nullable for exactly this reason; it becomes meaningful once real job
// matching exists).
model Application {
  id                 String            @id @default(cuid())
  candidate_id       String
  job_id             String?
  application_status ApplicationStatus @default(submitted)
  cover_letter       String?           @db.Text
  internal_notes     String?           @db.Text
  interview_date     DateTime?
  submitted_at       DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  // Section 1 — Programme Selection. Up to 3 alternatives are requested
  // because vacancy/embassy capacity varies by country (form's own words).
  preferred_country_1_id String?
  preferred_country_1    Country?  @relation("PreferredCountry1", fields: [preferred_country_1_id], references: [id], onDelete: SetNull)
  preferred_country_2_id String?
  preferred_country_2    Country?  @relation("PreferredCountry2", fields: [preferred_country_2_id], references: [id], onDelete: SetNull)
  preferred_country_3_id String?
  preferred_country_3    Country?  @relation("PreferredCountry3", fields: [preferred_country_3_id], references: [id], onDelete: SetNull)
  preferred_sector_id    String?
  preferred_sector       Sector?   @relation(fields: [preferred_sector_id], references: [id], onDelete: SetNull)
  earliest_travel_date   DateTime?
  prior_eu_visa_applied  String?   @db.Text // "Yes / No / Where" — kept free-text per the form

  // Section 3 — Document Checklist: self-reported "can you provide this?"
  // at submission time, not the documents themselves (those are uploaded
  // later, from the candidate's own dashboard, once an account exists).
  documents_available String[]

  // Section 5 — Visa & Travel Readiness. current_location_country_id is
  // also what drives round-robin recruiter assignment for a self-service
  // submission (matched against User.assigned_country_id) — a real
  // Country FK, not free text, scoped in the UI to the source-market
  // regions (Africa, Middle East & Gulf), not the Europe destination list.
  current_location_country_id       String?
  current_location_country          Country?        @relation("CurrentLocationCountry", fields: [current_location_country_id], references: [id], onDelete: SetNull)
  holds_schengen_visa               String?         @db.Text
  prior_visa_refusals               String?         @db.Text
  available_for_embassy_appointment Boolean         @default(false)
  willing_to_start_within_30_days   Boolean         @default(false)
  preferred_contact_channel         ContactChannel?

  // Section 4 — Payment Plan Acknowledgement (the candidate's "I understand" tick)
  payment_plan_acknowledged Boolean @default(false)

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  job       Job?      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  case      Case?

  @@index([candidate_id])
  @@index([job_id])
  @@index([current_location_country_id])
}

model Payment {
  id             String        @id @default(cuid())
  user_id        String
  job_id         String
  amount         Float
  currency       String        @default("USD")
  payment_method String // "stripe" or "paypal"
  payment_status PaymentStatus @default(pending)
  transaction_id String?       @unique
  created_at     DateTime      @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([job_id])
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

// ── Phase 4: Extended Mobility Lifecycle ────────────────────────────────

enum CaseStage {
  application_submitted
  verification
  offer_issued
  initial_payment
  permit_processing
  permit_delivered
  final_payment
  visa_application
  visa_guidance
  visa_approved
  travel_settlement
}

model Case {
  id             String      @id @default(cuid())
  application_id String      @unique
  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  current_stage  CaseStage   @default(application_submitted)
  // Expected completion of the CURRENT stage — surfaced as an in-app urgency
  // indicator (FR-4.4: "deadlines and reminders"), not a push-notification trigger.
  stage_deadline DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  stage_events        CaseStageEvent[]
  contract            Contract?
  payments            CasePayment[]
  retention_follow_up RetentionFollowUp?

  @@index([current_stage])
}

model CaseStageEvent {
  id           String    @id @default(cuid())
  case_id      String
  case         Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  stage        CaseStage
  owner_id     String?
  owner        User?     @relation("CaseStageOwner", fields: [owner_id], references: [id], onDelete: SetNull)
  entered_at   DateTime  @default(now())
  completed_at DateTime?
  notes        String?   @db.Text

  @@index([case_id])
  @@index([stage])
}

model RetentionFollowUp {
  id           String    @id @default(cuid())
  case_id      String    @unique
  case         Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  due_at       DateTime // +90 days from travel_settlement completion
  completed_at DateTime?
  notes        String?   @db.Text
}

// Matches the Candidate Information Form's 3-stage payment plan exactly:
// documentation (Stage 1 · 20%, on engagement), permit (Stage 2 · 40%,
// after the work permit is issued), visa (Stage 3 · 40%, after the visa
// is granted).
enum MilestonePaymentType {
  documentation
  permit
  visa
}

model CasePayment {
  id                String               @id @default(cuid())
  case_id           String
  case              Case                 @relation(fields: [case_id], references: [id], onDelete: Cascade)
  type              MilestonePaymentType
  amount            Float
  currency          String               @default("USD")
  receipt_reference String? // an invoice/receipt number, or a linked Document id
  recorded_by       String
  recorder          User                 @relation("CasePaymentRecorder", fields: [recorded_by], references: [id], onDelete: Cascade)
  recorded_at       DateTime             @default(now())

  @@index([case_id])
}

// Admin-configurable milestone-payment policy (SRS FR-4.5) — defaults
// disabled so no leadership sign-off gates the code shipping; an admin
// enables/configures amounts (globally or per destination country) whenever
// the business decides. Case-payment recording reads this policy at
// runtime rather than a hardcoded rule.
model FeePolicy {
  id                   String   @id @default(cuid())
  country_id           String? // null = global default; a country-specific row overrides it
  country              Country? @relation(fields: [country_id], references: [id], onDelete: SetNull)
  enabled              Boolean  @default(false)
  documentation_amount Float?
  permit_amount        Float?
  visa_amount          Float?
  currency             String   @default("USD")
  updated_by           String
  updater              User     @relation("FeePolicyUpdater", fields: [updated_by], references: [id], onDelete: Cascade)
  updated_at           DateTime @updatedAt

  @@index([country_id])
}

enum ContractStatus {
  draft
  sent
  signed
}

// Contract generation + signature capture (FR-4.3). Signature is a real,
// legally-recognized "simple electronic signature" (typed full-name
// attestation + authenticated session + timestamp + IP) — deliberate
// groundwork ahead of Phase 5's e-signature vendor integration (per the
// platform recommendation, DocuSign/Dropbox Sign is an "integrate", not a
// build, and explicitly scoped to Phase 5), not a placeholder.
model Contract {
  id             String         @id @default(cuid())
  case_id        String         @unique
  case           Case           @relation(fields: [case_id], references: [id], onDelete: Cascade)
  content        String         @db.Text // generated contract body (merged from candidate/job/case data)
  status         ContractStatus @default(draft)
  signed_by_name String?
  signed_at      DateTime?
  signed_ip      String?
  created_by     String
  creator        User           @relation("ContractCreator", fields: [created_by], references: [id], onDelete: Cascade)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
}

// ── Phase 5: Partner CRM (SRS FR-5.1, FR-5.2) ───────────────────────────
// Partners get their own admin-provisioned login and submit candidates
// themselves through their own portal (PartnerCandidate, below) — they do
// their own screening/verification/documents, so these candidates never
// enter Vertex's internal recruiter/screening/verification funnel
// (Candidate/CandidateLifecycleStatus). See docs/PLATFORM_ARCHITECTURE.md
// for the confirmed-deferred FR-5.3-5.9 integrations this phase excludes.

enum PartnerType {
  travel_agency
  visa_consultancy
  manpower_supplier
  other
}

enum PartnerStatus {
  pending
  active
  suspended
}

enum MouStatus {
  none
  sent
  signed
}

// A recruitment/travel agency or manpower supplier that sources candidate
// leads (Agency Application Form). country_of_operation is free text, not
// a Country FK — an agency can be based anywhere, not just Vertex's
// current programme-destination reference list.
model Partner {
  id                           String        @id @default(cuid())
  name                         String
  partner_type                 PartnerType
  country_of_operation         String
  business_registration_number String?
  contact_name                 String
  contact_email                String
  contact_phone                String
  status                       PartnerStatus @default(pending)
  mou_status                   MouStatus     @default(none)
  mou_signed_at                DateTime?
  notes                        String?       @db.Text
  created_at                   DateTime      @default(now())
  updated_at                   DateTime      @updatedAt

  // The partner's own login (SRS FR-5.1) — nullable until admin
  // provisions one, same shape as Candidate.user_id.
  user_id String? @unique
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  candidates         Candidate[]
  partner_candidates PartnerCandidate[]

  @@index([status])
}

enum PartnerCandidateStatus {
  submitted
  under_review
  job_assigned
  rejected
}

// A candidate a partner submits through its own portal — deliberately
// separate from Candidate/Application (not the same funnel): the partner
// has already screened/verified them, so none of Vertex's internal
// CandidateLifecycleStatus stages apply. Mirrors the Agency Application
// Form's Sections 2-6 (Section 1, Agency Information, is already captured
// on the Partner record above, not per-submission).
model PartnerCandidate {
  id         String                 @id @default(cuid())
  partner_id String
  partner    Partner                @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  status     PartnerCandidateStatus @default(submitted)

  // Section 3 — Candidate Personal Information
  full_name          String
  date_of_birth      DateTime
  nationality        String
  second_nationality String?
  passport_number    String
  passport_expiry    DateTime
  current_occupation String?
  highest_education  String?
  home_address       String?  @db.Text
  phone              String
  whatsapp_number    String?
  email              String
  marital_status     String?

  // Section 2 — Programme Selection
  preferred_country_1_id String
  preferred_country_1    Country  @relation("PartnerPreferredCountry1", fields: [preferred_country_1_id], references: [id], onDelete: Restrict)
  preferred_country_2_id String?
  preferred_country_2    Country? @relation("PartnerPreferredCountry2", fields: [preferred_country_2_id], references: [id], onDelete: SetNull)
  preferred_country_3_id String?
  preferred_country_3    Country? @relation("PartnerPreferredCountry3", fields: [preferred_country_3_id], references: [id], onDelete: SetNull)
  preferred_sector_id    String
  preferred_sector       Sector   @relation(fields: [preferred_sector_id], references: [id], onDelete: Restrict)
  earliest_travel_date   DateTime
  prior_eu_visa_applied  String?  @db.Text

  // Section 4 — Document Checklist (self-reported, same list as the CIF's)
  documents_available String[]

  // Section 5 — Payment Plan Acknowledgement
  payment_plan_acknowledged Boolean @default(false)

  // Section 6 — Visa & Travel Readiness
  current_location_country_id       String
  current_location_country          Country         @relation("PartnerCurrentLocation", fields: [current_location_country_id], references: [id], onDelete: Restrict)
  holds_schengen_visa               String?         @db.Text
  prior_visa_refusals               String?         @db.Text
  available_for_embassy_appointment Boolean         @default(false)
  willing_to_start_within_30_days   Boolean         @default(false)
  preferred_contact_channel         ContactChannel?

  // Vertex-side review/assignment — groundwork for the future job-
  // assignment step (SRS FR-5.1); not exercised by any code path yet.
  reviewed_by          String?
  reviewer             User?      @relation("PartnerCandidateReviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)
  rejection_reason     String?    @db.Text
  bridged_candidate_id String?    @unique
  bridged_candidate    Candidate? @relation(fields: [bridged_candidate_id], references: [id], onDelete: SetNull)

  submitted_at DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([partner_id])
  @@index([status])
}

enum EmployerClientStatus {
  active
  inactive
}

// The employer a vacancy is actually for (SRS FR-5.2) — distinct from
// Partner (which sources candidates, not jobs).
model EmployerClient {
  id            String               @id @default(cuid())
  name          String
  country       String
  industry      String?
  contact_name  String
  contact_email String
  contact_phone String
  status        EmployerClientStatus @default(active)
  notes         String?              @db.Text
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt

  jobs Job[]

  @@index([status])
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updated_at  DateTime @default(now()) @updatedAt
}

model KnowledgeArticle {
  id         String   @id @default(cuid())
  title      String
  category   String   @default("General")
  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model EmailTemplate {
  event      String   @id // e.g., "job_applied", "payment_receipt", "status_update"
  subject    String
  body_html  String   @db.Text
  updated_at DateTime @default(now()) @updatedAt
}
