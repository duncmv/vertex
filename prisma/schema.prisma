// Vertex International Recruitment — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  candidate
  admin
}

enum ApplicationStatus {
  submitted
  under_review
  interview
  approved
  rejected
}

enum JobStatus {
  active
  closed
  draft
}

model User {
  id             String    @id @default(cuid())
  full_name      String
  email          String    @unique
  password_hash  String?
  google_id      String?   @unique
  phone          String?
  country        String?
  role           Role      @default(candidate)
  email_verified Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  candidate      Candidate?
  payments       Payment[]

  @@index([email])
}

model Candidate {
  id              String   @id @default(cuid())
  user_id         String   @unique
  passport_number String?
  date_of_birth   DateTime?
  nationality     String?
  cv_file         String?   // stored file path / URL
  passport_scan   String?   // stored file path / URL
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  applications    Application[]

  @@index([user_id])
}

model Job {
  id              String    @id @default(cuid())
  title           String
  country         String
  city            String
  category        String?
  salary_range    String?
  job_description String    @db.Text
  requirements    String    @db.Text
  status          JobStatus @default(active)
  application_fee Float?    @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  applications    Application[]
  payments        Payment[]

  @@index([status])
  @@index([country])
}

model Application {
  id                 String            @id @default(cuid())
  candidate_id       String
  job_id             String
  application_status ApplicationStatus @default(submitted)
  cover_letter       String?           @db.Text
  internal_notes     String?           @db.Text
  interview_date     DateTime?
  submitted_at       DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  candidate          Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  job                Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([candidate_id, job_id])
  @@index([candidate_id])
  @@index([job_id])
}

model Payment {
  id              String        @id @default(cuid())
  user_id         String
  job_id          String
  amount          Float
  currency        String        @default("USD")
  payment_method  String        // "stripe" or "paypal"
  payment_status  PaymentStatus @default(pending)
  transaction_id  String?       @unique
  created_at      DateTime      @default(now())

  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  job             Job           @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([job_id])
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updated_at  DateTime @default(now()) @updatedAt
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("General")
  content     String   @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model EmailTemplate {
  event       String   @id // e.g., "job_applied", "payment_receipt", "status_update"
  subject     String
  body_html   String   @db.Text
  updated_at  DateTime @default(now()) @updatedAt
}
