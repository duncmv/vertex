// Vertex International Recruitment — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  candidate
  regional_recruiter
  country_supervisor
  inhouse_supervisor
  director
  admin
}

enum ApplicationStatus {
  submitted
  under_review
  interview
  approved
  rejected
}

enum JobStatus {
  active
  closed
  draft
}

model User {
  id             String   @id @default(cuid())
  full_name      String
  email          String   @unique
  password_hash  String?
  google_id      String?  @unique
  phone          String?
  country        String?
  role           Role     @default(candidate)
  email_verified Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Agent-network structure (SRS FR-1.1, FR-1.3, FR-1.4)
  supervisor_id       String?
  supervisor          User?    @relation("Supervision", fields: [supervisor_id], references: [id], onDelete: SetNull)
  reports             User[]   @relation("Supervision")
  assigned_country_id String?
  assigned_country    Country? @relation(fields: [assigned_country_id], references: [id], onDelete: SetNull)

  candidate          Candidate?
  payments           Payment[]
  sourced_candidates Candidate[] @relation("RecruiterCandidates")
  submitted_reports  Report[]    @relation("SubmittedReports")
  campaigns_created  Campaign[]  @relation("CampaignCreator")

  @@index([email])
  @@index([supervisor_id])
  @@index([assigned_country_id])
}

model Region {
  id        String    @id @default(cuid())
  name      String    @unique
  countries Country[]

  campaign_targets CampaignTarget[]
}

model Country {
  id        String @id @default(cuid())
  name      String @unique
  region_id String
  region    Region @relation(fields: [region_id], references: [id], onDelete: Restrict)

  users            User[]
  candidates       Candidate[]
  reports          Report[]
  campaign_targets CampaignTarget[]

  @@index([region_id])
}

enum CandidateSource {
  self_registered
  recruiter_sourced
}

enum CandidateLifecycleStatus {
  identified
  screened
  guided_to_apply
  submitted
  reported
  verified
  approved
}

model Candidate {
  id              String    @id @default(cuid())
  user_id         String?   @unique // nullable: a recruiter-sourced lead may not have an account yet (SRS FR-2.1)
  passport_number String?
  date_of_birth   DateTime?
  nationality     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Pre-registration identity (SRS FR-2.1, FR-2.8) — only meaningful when
  // user_id is null. Once a User is linked, that record's full_name/
  // phone/email become authoritative instead.
  full_name String?
  phone     String?
  email     String?

  // Target role/position (SRS FR-2.8 candidate-list data point). Free text
  // for now — no formal job/case-matching model exists yet (Phase 4).
  desired_role String?

  // Agent-network attribution (SRS FR-1.4, FR-2.3)
  source           CandidateSource          @default(self_registered)
  recruiter_id     String?
  recruiter        User?                    @relation("RecruiterCandidates", fields: [recruiter_id], references: [id], onDelete: SetNull)
  country_id       String?
  country          Country?                 @relation(fields: [country_id], references: [id], onDelete: SetNull)
  lifecycle_status CandidateLifecycleStatus @default(identified)

  // Screening gate (SRS FR-2.5) + verification-return workflow (FR-2.7)
  consent_given Boolean   @default(false)
  consent_at    DateTime?
  return_reason String?   @db.Text

  user         User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  applications Application[]
  documents    Document[]

  @@index([user_id])
  @@index([recruiter_id])
  @@index([country_id])
}

enum DocumentType {
  cv
  passport
  transcript
  certificate
  medical
  police_clearance
  contract
  visa
  other
}

enum VerificationStatus {
  pending
  verified
  rejected
}

model Document {
  id                  String             @id @default(cuid())
  candidate_id        String
  type                DocumentType
  storage_path        String // private-bucket path; never a public URL (SRS FR-1.6)
  verification_status VerificationStatus @default(pending)
  verified_by         String?
  verified_at         DateTime?
  uploaded_at         DateTime           @default(now())

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)

  @@index([candidate_id])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  entity_type String
  entity_id   String
  action      String // create | update | delete | verify | approve
  actor_id    String?
  before      Json?
  after       Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([actor_id])
}

// ── Phase 3: Control, Reporting & Governance ────────────────────────────

enum ReportCycle {
  daily
  weekly
  monthly
}

enum ScopeLevel {
  recruiter
  country
}

enum ReportStatus {
  draft
  submitted
  verified
  consolidated
  returned
}

// A recruiter's daily/weekly submission (scope_level: recruiter) rolls up
// via parent_report_id into their supervisor's country-level report
// (scope_level: country) — the escalation path (SRS FR-3.7) made concrete
// as data, not just a permission chain. `content` snapshots the candidate
// list / KPI summary at submission time (SRS FR-3.4) — a deliberate,
// disclosed duplication of data computable from Candidate/Application,
// since a report is a point-in-time record, not a live view: it must not
// silently change after submission just because the underlying candidates
// move on to new statuses.
model Report {
  id               String       @id @default(cuid())
  type             ReportCycle
  scope_level      ScopeLevel
  country_id       String?
  country          Country?     @relation(fields: [country_id], references: [id], onDelete: SetNull)
  submitted_by     String
  submitter        User         @relation("SubmittedReports", fields: [submitted_by], references: [id], onDelete: Cascade)
  period_start     DateTime
  period_end       DateTime
  status           ReportStatus @default(draft)
  content          Json
  return_reason    String?      @db.Text
  parent_report_id String?
  parent_report    Report?      @relation("ReportRollup", fields: [parent_report_id], references: [id], onDelete: SetNull)
  child_reports    Report[]     @relation("ReportRollup")
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@index([submitted_by])
  @@index([country_id])
  @@index([status])
  @@index([type, period_start])
}

enum CampaignStatus {
  draft
  active
  closed
}

// Criteria/requirements are free-form per campaign (roles, quotas,
// eligibility rules) — modeled as Json rather than a rigid schema since
// the SRS doesn't specify a fixed shape and campaigns vary widely by
// destination market (SRS FR-3.3).
model Campaign {
  id         String         @id @default(cuid())
  name       String
  criteria   Json
  status     CampaignStatus @default(draft)
  created_by String
  creator    User           @relation("CampaignCreator", fields: [created_by], references: [id], onDelete: Cascade)
  start_date DateTime
  end_date   DateTime // a campaign has a bounded timeline (SRS FR-3.3), not an open-ended one
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  targets CampaignTarget[]

  @@index([status])
  @@index([created_by])
}

enum CampaignMetric {
  agent_signups
  applicant_flow
  conversion_rate
}

// A target cascades to exactly one country, one region, or neither
// (campaign-wide) — never more than one scope per row, so "actuals"
// aggregation always has an unambiguous target to compare against.
model CampaignTarget {
  id           String         @id @default(cuid())
  campaign_id  String
  campaign     Campaign       @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  metric       CampaignMetric
  country_id   String?
  country      Country?       @relation(fields: [country_id], references: [id], onDelete: SetNull)
  region_id    String?
  region       Region?        @relation(fields: [region_id], references: [id], onDelete: SetNull)
  target_value Float
  created_at   DateTime       @default(now())

  @@index([campaign_id])
  @@index([country_id])
  @@index([region_id])
}

model Job {
  id              String    @id @default(cuid())
  title           String
  country         String
  city            String
  category        String?
  salary_range    String?
  job_description String    @db.Text
  requirements    String    @db.Text
  status          JobStatus @default(active)
  application_fee Float?    @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  applications Application[]
  payments     Payment[]

  @@index([status])
  @@index([country])
}

model Application {
  id                 String            @id @default(cuid())
  candidate_id       String
  job_id             String
  application_status ApplicationStatus @default(submitted)
  cover_letter       String?           @db.Text
  internal_notes     String?           @db.Text
  interview_date     DateTime?
  submitted_at       DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([candidate_id, job_id])
  @@index([candidate_id])
  @@index([job_id])
}

model Payment {
  id             String        @id @default(cuid())
  user_id        String
  job_id         String
  amount         Float
  currency       String        @default("USD")
  payment_method String // "stripe" or "paypal"
  payment_status PaymentStatus @default(pending)
  transaction_id String?       @unique
  created_at     DateTime      @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([job_id])
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updated_at  DateTime @default(now()) @updatedAt
}

model KnowledgeArticle {
  id         String   @id @default(cuid())
  title      String
  category   String   @default("General")
  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model EmailTemplate {
  event      String   @id // e.g., "job_applied", "payment_receipt", "status_update"
  subject    String
  body_html  String   @db.Text
  updated_at DateTime @default(now()) @updatedAt
}
